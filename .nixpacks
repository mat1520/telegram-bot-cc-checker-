[phases.setup]
nixPkgs = ['php82']

[phases.install]
cmds = [
    'composer install --no-dev --optimize-autoloader',
    'mkdir -p bot',
    'cp -r *.php bot/',
    'cp -r Gateway Capsolver Tool Tool_Admin adyen bot/',
    'cp -r vendor bot/'
]

[start]
cmd = 'cd bot && php -S 0.0.0.0:$PORT index.php'

[deploy]
startCommand = "php -S 0.0.0.0:$PORT -t public/" 