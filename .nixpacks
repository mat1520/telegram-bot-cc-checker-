[phases.setup]
nixPkgs = ['php82', 'php82Packages.composer']

[phases.install]
cmds = [
    'mkdir -p public',
    'cp -r Telegram.php CurlX.php userAgent.php Class_Base.php bypass.php NovaFormat.php Gen_Card.php Gateway Capsolver Tool Tool_Admin adyen public/',
    'composer install --no-dev --optimize-autoloader --ignore-platform-reqs'
]

[start]
cmd = 'cd public && php -S 0.0.0.0:$PORT'

[deploy]
startCommand = "php -S 0.0.0.0:$PORT -t public/" 