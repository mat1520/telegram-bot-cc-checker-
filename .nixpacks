[phases.setup]
nixPkgs = ['php82']

[phases.install]
cmds = [
    'composer install --no-dev --optimize-autoloader',
    'mkdir -p app',
    'mv *.php app/',
    'mv Gateway Capsolver Tool Tool_Admin adyen app/',
    'mv app public/'
]

[start]
cmd = 'cd public && php -S 0.0.0.0:$PORT'

[deploy]
startCommand = "php -S 0.0.0.0:$PORT -t public/" 