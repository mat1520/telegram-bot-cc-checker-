[phases.setup]
nixPkgs = ['php82', 'php82Packages.composer']

[phases.install]
cmds = [
    'composer install --no-dev --optimize-autoloader --ignore-platform-reqs',
    'cp -r * public/ 2>/dev/null || true'
]

[start]
cmd = 'cd public && php -S 0.0.0.0:$PORT'

[deploy]
startCommand = "php -S 0.0.0.0:$PORT -t public/" 