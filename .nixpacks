[phases.setup]
nixPkgs = ['php82']

[phases.install]
cmds = [
    'rm -rf public',
    'mkdir public',
    'cp *.php public/',
    'cp -r Gateway Capsolver Tool Tool_Admin adyen public/',
    'composer install --no-dev --optimize-autoloader'
]

[start]
cmd = 'cd public && php -S 0.0.0.0:$PORT'

[deploy]
startCommand = "php -S 0.0.0.0:$PORT -t public/" 